# FATE & GRÂCE — Variables d'environnement
# Copiez ce fichier en .env et ajustez les valeurs

# URL de base de l'API Django (sans slash final)
REACT_APP_API_URL=http://localhost:8000/api

# URL WebSocket Django Channels (pour les notifications temps réel)
REACT_APP_WS_URL=ws://localhost:8000/ws

# Port de développement React (optionnel)
PORT=3000
